# Copy to .env on the EC2 instance and fill in values.
# Never commit the real .env file.

# Shared secret between the Mac agent and the backend.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FOCASSIST_TOKEN=CHANGE_ME

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=CHANGE_ME

# Your Telegram chat ID (send /start to the bot, then check the logs or
# use https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id)
TELEGRAM_CHAT_ID=CHANGE_ME

# SQLite database path (default: ~/.focassist/focassist.db)
# FOCASSIST_DB=/home/ubuntu/.focassist/focassist.db

# API bind address (default: 0.0.0.0:8000)
# FOCASSIST_API_HOST=0.0.0.0
# FOCASSIST_API_PORT=8000
